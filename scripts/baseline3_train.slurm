#!/bin/bash
#SBATCH --job-name=baseline3-train-da3mono
#SBATCH --account=cil_jobs
#SBATCH --time=14:00:00
#SBATCH --gpus=5060ti:1
#SBATCH --mem=24G
#SBATCH --output=/home/%u/monocular-depth-estimation/logs/slurm-%x-%j.out
#SBATCH --error=/home/%u/monocular-depth-estimation/logs/slurm-%x-%j.err

set -euo pipefail

USER_NAME="${USER:-nmeurer}"
REPO_DIR="${REPO_DIR:-/home/${USER_NAME}/monocular-depth-estimation}"
SCRATCH_ROOT="${SCRATCH_ROOT:-/work/scratch/${USER_NAME}}"
TEACHER_MODEL="${TEACHER_MODEL:-DA3-GIANT-1.1}"
BS3_MODE="${BS3_MODE:-full_head}"
VAL_SUBSET_STRATEGY="${VAL_SUBSET_STRATEGY:-manifest}"
VAL_INTERVAL_STEPS="${VAL_INTERVAL_STEPS:-500}"
EPOCHS="${EPOCHS:-3}"

# Pseudo-labels generated by the teacher job; set CACHE_DIR if you want another cache.
CACHE_DIR="${CACHE_DIR:-${SCRATCH_ROOT}/outputs/baseline3/pseudo_labels_${TEACHER_MODEL}}"

cd "${REPO_DIR}"

if [ -f "${REPO_DIR}/.env" ]; then
    set -a
    source "${REPO_DIR}/.env"
    set +a
fi

export HF_HOME="${HF_HOME:-${SCRATCH_ROOT}/hf_cache}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${SCRATCH_ROOT}/cache}"
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export SCRATCH_ROOT
export TEACHER_MODEL
export BS3_MODE
export VAL_SUBSET_STRATEGY
export VAL_INTERVAL_STEPS
export EPOCHS
if [ -n "${VAL_MANIFEST:-}" ]; then
    export VAL_MANIFEST
fi
mkdir -p "${HF_HOME}" "${XDG_CACHE_HOME}"

. /etc/profile.d/modules.sh
module add cuda/13.0

source "${REPO_DIR}/.venv/bin/activate"
PYTHON="${REPO_DIR}/.venv/bin/python"

echo "Job started at $(date)"
echo "Running on host $(hostname)"
echo "Using pseudo-label cache: ${CACHE_DIR}"
echo "Teacher model metadata: ${TEACHER_MODEL}"
echo "Training mode: ${BS3_MODE}"
echo "Epochs: ${EPOCHS}"
echo "Validation strategy: ${VAL_SUBSET_STRATEGY}"
echo "Validation interval steps: ${VAL_INTERVAL_STEPS}"
if [ -n "${VAL_MANIFEST:-}" ]; then
    echo "Validation manifest: ${VAL_MANIFEST}"
fi

"${PYTHON}" -c "import torch; print('CUDA available:', torch.cuda.is_available()); print('GPU:', torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'none')"

"${PYTHON}" -u src/bs3_pseudo_label_DA3_train.py \
  --cache "${CACHE_DIR}"

# Find the pred dir written by the training script (includes datetime in name)
PRED_DIR=$(find "${SCRATCH_ROOT}/models" -maxdepth 2 -name "preds" -path "*/baseline3-*" | sort | tail -1)
if [ -z "${PRED_DIR}" ]; then
    echo "ERROR: could not locate pred dir under ${SCRATCH_ROOT}/models"
    exit 1
fi

SUBMISSION_CSV="${PRED_DIR}/../baseline3_submission.csv"

"${PYTHON}" utils/create_submission.py \
  --pred-dir "${PRED_DIR}" \
  --out-csv "${SUBMISSION_CSV}"

echo "Submission written to ${SUBMISSION_CSV}"
echo "Job finished at $(date)"
